<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F6">

    <!-- ── Top App Bar ── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1976D2"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 Offline Dashboard"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackToMain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"
            android:textSize="13sp"
            android:padding="6dp" />
    </LinearLayout>

    <!-- ── No-data state ── -->
    <LinearLayout
        android:id="@+id/layoutNoData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:layout_margin="20dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📭"
            android:textSize="52sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Offline Data Available"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1C1E21"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Please visit the Home Page and tap 'Connect to Internet' to sync your data for offline use."
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp" />

    </LinearLayout>

    <!-- ── Fees Due Banner (shown above all content when expired) ── -->
    <LinearLayout
        android:id="@+id/bannerFeesDue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:orientation="vertical"
        android:background="#C62828"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        android:elevation="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️  FEES DUE — PLEASE PAY YOUR MEMBERSHIP FEES"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.03" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wi-Fi access is blocked. Visit Home Page to renew."
            android:textColor="#FFCDD2"
            android:textSize="12sp"
            android:layout_marginTop="3dp" />
    </LinearLayout>

    <!-- ── Main scrollable data content ── -->
    <ScrollView
        android:id="@+id/layoutData"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:visibility="gone"
        android:clipToPadding="false"
        android:paddingBottom="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="16dp">

            <!-- ── Survival Time Card ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEMBERSHIP TIME REMAINING"
                        android:textSize="10sp"
                        android:textColor="#1976D2"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvSurvivalTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00:00"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:textColor="#2ECC71"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#E8F5E9"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/tvValidUntil"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅 Valid until: —"
                            android:textSize="13sp"
                            android:textColor="#2E7D32"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Wi-Fi Connect Buttons Card ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#F0F7FF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONNECT TO LIBRARY WI-FI"
                        android:textSize="10sp"
                        android:textColor="#1976D2"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="10dp" />

                    <Button
                        android:id="@+id/btnWifi1"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="🛜 Connect to Internet"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/btn_press_home"
                        android:textSize="14sp"
                        android:layout_marginBottom="10dp"
                        android:stateListAnimator="@null" />

                    <!-- Wi-Fi 1 result message — appears directly under btnWifi1 -->
                    <LinearLayout
                        android:id="@+id/layoutWifiResult1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="10dp"
                        android:padding="14dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvWifiResult1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1C1E21"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvWifiSubtext1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="#555555" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnWifi2"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="🛜 Connect to Internet 2"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/btn_press_dashboard"
                        android:textSize="14sp"
                        android:stateListAnimator="@null" />

                    <!-- Wi-Fi 2 result message — appears directly under btnWifi2 -->
                    <LinearLayout
                        android:id="@+id/layoutWifiResult2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:padding="14dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvWifiResult2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1C1E21"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvWifiSubtext2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="#555555" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── User Profile Card ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEMBER PROFILE"
                        android:textSize="10sp"
                        android:textColor="#1976D2"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="14dp" />

                    <!-- Full Name row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="12dp"
                        android:layout_marginBottom="2dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FULL NAME"
                            android:textSize="9sp"
                            android:textColor="#1976D2"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="3dp" />
                        <TextView
                            android:id="@+id/tvName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="16sp"
                            android:textColor="#1C1E21" />
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#EEEEEE"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>

                    <!-- Father Name row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="12dp"
                        android:layout_marginBottom="2dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FATHER'S NAME"
                            android:textSize="9sp"
                            android:textColor="#1976D2"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="3dp" />
                        <TextView
                            android:id="@+id/tvFather"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="16sp"
                            android:textColor="#1C1E21" />
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#EEEEEE"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>

                    <!-- Mobile row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="12dp"
                        android:layout_marginBottom="2dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MOBILE"
                            android:textSize="9sp"
                            android:textColor="#1976D2"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="3dp" />
                        <TextView
                            android:id="@+id/tvPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="16sp"
                            android:textColor="#1C1E21" />
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#EEEEEE"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>

                    <!-- Address row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ADDRESS"
                            android:textSize="9sp"
                            android:textColor="#1976D2"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="3dp" />
                        <TextView
                            android:id="@+id/tvAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="16sp"
                            android:textColor="#1C1E21" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Sample Data / Preview Button (testing) ── -->
            <Button
                android:id="@+id/btnLoadSampleData"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🧪 Load Sample Data (Preview)"
                android:textColor="#1976D2"
                android:background="@drawable/btn_press_exit"
                android:textSize="13sp"
                android:layout_marginBottom="20dp"
                android:stateListAnimator="@null"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
