<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1976D2">

    <androidx.cardview.widget.CardView
        android:id="@+id/mainCard"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="invisible"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="28dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/appIcon"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginBottom="14dp"
                android:visibility="invisible" />

            <TextView
                android:id="@+id/appName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rakshapal Library"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="#1976D2"
                android:letterSpacing="0.05"
                android:gravity="center"
                android:visibility="invisible" />

            <View
                android:id="@+id/divider"
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#1976D2"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"
                android:visibility="invisible" />

            <!-- Version is set dynamically in MainActivity -->
            <TextView
                android:id="@+id/appVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#999999"
                android:letterSpacing="0.08"
                android:layout_marginBottom="18dp"
                android:gravity="center"
                android:visibility="invisible" />

            <!-- ── Survival Timer (shown when Wi-Fi suggestion is active) ── -->
            <LinearLayout
                android:id="@+id/survivalTimerBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#F0F7FF"
                android:padding="10dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ Wi-Fi Access Remaining"
                    android:textSize="10sp"
                    android:textColor="#1976D2"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvSurvivalTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00:00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="#1976D2"
                    android:letterSpacing="0.05" />

            </LinearLayout>

            <!-- Go to Home Page — taller, multiline allowed -->
            <Button
                android:id="@+id/btnHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:text="🏠 Go to Home Page"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_press_home"
                android:textSize="15sp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp"
                android:visibility="invisible" />

            <!-- Exit App -->
            <Button
                android:id="@+id/btnExit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:text="✕  Exit App"
                android:textColor="#1976D2"
                android:background="@drawable/btn_press_exit"
                android:textSize="15sp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:stateListAnimator="@null"
                android:visibility="invisible" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>
